# Production Environment Variables
# Copy this file to .env.production and update the values

# Database Configuration
DATABASE_URL=postgresql://username:password@your-postgres-host:5432/algotask
POSTGRES_PASSWORD=your-secure-production-password

# Backend Configuration
JWT_PASSKEY=your-super-secure-jwt-key-at-least-32-characters-long-for-production-use
SALT_ROUNDS=12
PORT=8000
COMPILER_PORT=http://compiler:3002

# Google AI Configuration
GOOGLE_GEMINI_API_KEY=your-production-google-gemini-api-key

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL=https://your-api-domain.com

# Security Headers
NODE_ENV=production
